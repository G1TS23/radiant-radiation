---
import Layout from "../layouts/Layout.astro";
import "../styles/terminal.css";
---

<Layout title="radiant-radiation">
  <div class="layout">
    <aside class="keys" aria-label="keyboard shortcuts">
      <p class="keys-head">keys</p>
      <ul>
        <li><kbd>↑↓←→</kbd> move</li>
        <li><kbd>space</kbd> flip</li>
        <li><kbd>z</kbd> undo</li>
        <li><kbd>r</kbd> reset</li>
        <li><kbd>n</kbd> new</li>
        <li><kbd>d</kbd> difficulty</li>
        <li><kbd>t</kbd> theme</li>
      </ul>
    </aside>
    <main id="game" class="cli" aria-label="radiant-radiation puzzle"></main>
    <div class="hist-spacer" aria-hidden="true"></div>
    <aside id="history" class="history" aria-label="game history"></aside>
    <div class="hist-backdrop" aria-hidden="true"></div>
  </div>
</Layout>

<script>
  import "../game/main.ts";
</script>
